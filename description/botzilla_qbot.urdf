<?xml version="1.0"?>
<robot name="botzilla_qbot">

  <!-- =============== Base Footprint =============== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- =============== Base Link (Chassis) =============== -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.17" length="0.09"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.17" length="0.09"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.4"/>
      <inertia ixx="0.019" ixy="0.0" ixz="0.0" iyy="0.019" iyz="0.0" izz="0.034"/>
    </inertial>
  </link>

  <!-- =============== Left Wheel =============== -->
  <link name="wheel_left_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 0.115 -0.025" rpy="-1.570796 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- =============== Right Wheel =============== -->
  <link name="wheel_right_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.02"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -0.115 -0.025" rpy="-1.570796 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- =============== Caster Wheel =============== -->
  <link name="caster_front_link">
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front_link"/>
    <origin xyz="0.115 0.0 -0.045" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_link">
    <collision>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </collision>
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.135 0.0 -0.045" rpy="0 0 0"/>
  </joint>

  <!-- =============== RGB-D Camera (Kinect) =============== -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.06 0.25 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.25 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.15 0 0.07" rpy="0 0 0"/>
  </joint>

  <!-- =============== Pushing Arms (Front Plates) =============== -->
  <!-- Left Arm -->
  <link name="arm_left_link">
    <visual>
      <geometry>
        <box size="0.15 0.02 0.08"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.02 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="arm_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_left_link"/>
    <!-- Positioned at the front (+x), shifted left (+y) and angled slightly -->
    <origin xyz="0.18 0.06 -0.01" rpy="0 0 0.3"/> 
  </joint>

  <!-- Right Arm -->
  <link name="arm_right_link">
    <visual>
      <geometry>
        <box size="0.15 0.02 0.08"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.15 0.02 0.08"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="arm_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_right_link"/>
    <!-- Positioned at the front (+x), shifted right (-y) and angled slightly -->
    <origin xyz="0.18 -0.06 -0.01" rpy="0 0 -0.3"/>
  </joint>

  <!-- =============== Gazebo Plugins (Harmonic) =============== -->
  <gazebo>
    <!-- Differential Drive -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.23</wheel_separation>
      <wheel_radius>0.035</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="rgbd_camera" type="rgbd_camera">
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>RGB_INT8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate>
      <visualize>true</visualize>
      <topic>camera</topic>
    </sensor>
  </gazebo>

</robot>